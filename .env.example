# ─────────────────────────────────────────────
#  DEMON BOT V7 — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── BOT IDENTITY ──────────────────────────────
BOT_NAME=DEMON BOT V7
OWNER_NAME=King Fixed
# Your WhatsApp number with country code, no + or spaces
OWNER_NUMBER=50955394345
PREFIX=.

# ── BOT MODE ──────────────────────────────────
# "public" = anyone can use | "private" = owner only
MODE=public

# ── AI (required for .ai command) ─────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get it free at: https://aistudio.google.com/apikey

# ── OPTIONAL API KEYS ─────────────────────────
# OPENWEATHER_API_KEY=your_key   # for .weather command
# REMOVEBG_API_KEY=your_key      # for .removebg command

# ── TIMEZONE ──────────────────────────────────
TIMEZONE=America/Port-au-Prince

# ── PAIRING CODE (optional) ───────────────────
# Set to "true" to use phone number pairing instead of QR scan
USE_PAIRING_CODE=false

# ── PORT (Render sets this automatically) ─────
PORT=3000
